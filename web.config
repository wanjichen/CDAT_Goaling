<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- 1. 处理程序映射：将所有请求交给 FastCGI -->
    <handlers>
      <add name="FlaskHandler" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="C:\python311\python.exe|C:\python311\Lib\site-packages\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
    
    <!-- 2. 详细错误显示：方便 Debug -->
    <httpErrors errorMode="DetailedLocalOnly" />

    <!--
      Note: FastCGI application registrations are typically configured at the server level.
      We keep handler + appSettings here; if you rely on server-level fastCgi entries, make sure
      they use WSGI_APP (not WSGI_HANDLER) and point WSGI_LOG to a writable path.
    -->
  </system.webServer>

  <appSettings>
    <!-- 3. Flask 配置项 -->
  <!-- wfastcgi expects WSGI_APP (module.variable) for the Flask WSGI app object. -->
  <add key="WSGI_APP" value="app.app" />
    <!-- Compatibility: some wfastcgi builds require WSGI_HANDLER instead of WSGI_APP. -->
  <add key="WSGI_HANDLER" value="app.app" />
    
    <!-- 项目根目录的绝对路径 (Intel 机器上建议使用绝对路径) -->
  <add key="PYTHONPATH" value="C:\inetpub\wwwroot\cdatdelivery\CDAT_Goaling" />
    
    <!-- 错误日志路径：500 错误的真凶会写在这里 -->
  <!-- Write wfastcgi stdout/stderr here so 500 errors have a stack trace. -->
  <add key="WSGI_LOG" value="C:\inetpub\wwwroot\cdatdelivery\CDAT_Goaling\logs\wfastcgi.log" />

  <!-- IIS Application path prefix (used by PrefixMiddleware in app.py). -->
  <add key="URL_PREFIX" value="/CDAT_Goaling" />
    
    <!-- 可选：如果子站点路由有问题，可以尝试设置这个 -->
    <!-- <add key="WSGI_RESTART_FILE_REGEX" value=".*((\.py)|(\.config))$" /> -->
  </appSettings>

  <system.web>
    <!-- 确保关闭 ASP.NET 的默认错误页 -->
  <customErrors mode="Off" />
  </system.web>
</configuration>
